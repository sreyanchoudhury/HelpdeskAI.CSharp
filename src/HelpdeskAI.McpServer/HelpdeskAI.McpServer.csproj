<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>HelpdeskAI.McpServer</RootNamespace>
    <AssemblyName>HelpdeskAI.McpServer</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!--
      MCP server-side hosting: HTTP+SSE transport, tool discovery, DI integration.
      Latest stable: 0.3.0-preview.3 (AspNetCore extension on top of core 1.0.0)
    -->
    <PackageReference Include="ModelContextProtocol.AspNetCore" Version="1.0.0" />

    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" Version="11.0.0-preview.1.26104.118" />
  </ItemGroup>

</Project>
